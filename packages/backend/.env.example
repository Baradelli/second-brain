DATABASE_URL="postgresql://cerebro:cerebro@localhost:5432/cerebro?schema=public"
PORT=3333
# Diretório em disco onde os anexos enviados são gravados (servidos em /uploads/*).
UPLOAD_DIR="uploads"
# Origens permitidas no CORS (separadas por vírgula). Vazio = libera qualquer origem (dev).
# Ex.: CORS_ORIGIN="http://localhost:5174,http://localhost:5173"
CORS_ORIGIN=
