  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@cerebro/shared": "workspace:*",
    "@fastify/cors": "^10",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9",
    "@fastify/static": "^8",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^3.0.0",
    "luxon": "^3.7.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
