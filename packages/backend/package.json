{
  "name": "@cerebro/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/http/main.ts",
    "build": "tsc",
    "start": "node dist/http/main.js",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
