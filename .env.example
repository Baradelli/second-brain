# Copie para packages/backend/.env e ajuste se necessário
DATABASE_URL="postgresql://cerebro:cerebro@localhost:5432/cerebro?schema=public"

# Porta do backend Fastify
PORT=3333

# Assinatura dos tokens JWT — OBRIGATÓRIO definir um valor forte em produção
# JWT_SECRET="troque-por-um-segredo-forte"

# Modo conectado da IA (opcional): chave da Anthropic, SÓ no servidor.
# Sem ela o app continua funcionando no modo "copiar prompt".
# ANTHROPIC_API_KEY="sk-ant-..."
