{
  "name": "segundo-cerebro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev:backend": "pnpm --filter @cerebro/backend dev",
    "dev:web": "pnpm --filter @cerebro/web dev",
    "dev:mobile": "pnpm --filter @cerebro/mobile dev",
    "test": "pnpm -r test",
    "test:integration": "pnpm -r test:integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "prisma:migrate": "pnpm --filter @cerebro/backend run prisma:migrate",
    "prisma:studio": "pnpm --filter @cerebro/backend run prisma:studio",
    "prisma:seed": "pnpm --filter @cerebro/backend run seed"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
